---
import Layout from '~/layouts/Layout.astro'
import { repoRegistry, hiddenRepos } from '~/data/projectRegistry'

interface GitHubRepo {
  id: number
  name: string
  description: string | null
  html_url: string
  homepage: string | null
  stargazers_count: number
  forks_count: number
  language: string | null
  topics: string[]
  updated_at: string
  fork: boolean
}

let repos: GitHubRepo[] = []
let fetchError: string | null = null

try {
  const response = await fetch(
    'https://api.github.com/users/anmolsharma152/repos?sort=updated&per_page=50',
  )
  if (!response.ok) throw new Error(`GitHub API: ${response.status}`)
  const data: GitHubRepo[] = await response.json()

  repos = data
    .filter(
      (repo) =>
        !repo.fork &&
        !hiddenRepos.some((h) => repo.name.toLowerCase().includes(h.toLowerCase())),
    )
    .sort((a, b) => {
      const aHome = a.homepage && a.homepage.trim() !== '' ? 1 : 0
      const bHome = b.homepage && b.homepage.trim() !== '' ? 1 : 0
      if (aHome !== bHome) return bHome - aHome
      return new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime()
    })
} catch (e) {
  fetchError = e instanceof Error ? e.message : 'Failed to fetch repos'
}

function getRegistryKey(name: string): string | undefined {
  for (const key of Object.keys(repoRegistry)) {
    if (name.toLowerCase().includes(key.toLowerCase())) return key
  }
  return undefined
}

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  })
}
---

<Layout>
  <main class="content">
    <h1>Engineered Systems</h1>

    {
      fetchError ? (
        <div class="error-state">
          <p class="error-msg">[ERR] {fetchError}</p>
          <a
            href="https://github.com/anmolsharma152?tab=repositories"
            target="_blank"
            rel="noopener"
            class="fallback-link"
          >
            View all projects on GitHub →
          </a>
        </div>
      ) : (
        <div class="projects-grid">
          {
            repos.map((repo) => {
              const registryKey = getRegistryKey(repo.name)
              const registryEntry = registryKey ? repoRegistry[registryKey] : null
              const description = registryEntry?.desc ?? repo.description ?? 'System architecture available in repository.'
              const tags = registryEntry?.tags ?? (repo.language ? [repo.language] : [])

              return (
                <article class="project-card">
                  <div class="project-head">
                    <h2 class="project-name">{repo.name.replace(/-/g, ' ')}</h2>
                    {repo.homepage && (
                      <a href={repo.homepage} target="_blank" rel="noopener" class="live-link">
                        Live ↗
                      </a>
                    )}
                  </div>
                  <p class="project-desc">{description}</p>
                  <div class="tags">
                    {tags.map((tag) => <span class="tag">{tag}</span>)}
                  </div>
                  <div class="project-meta">
                    <span class="lang">{repo.language}</span>
                    <span class="stars">★ {repo.stargazers_count}</span>
                    <span class="updated">Updated {formatDate(repo.updated_at)}</span>
                  </div>
                  <a href={repo.html_url} target="_blank" rel="noopener" class="project-link">
                    View Repository →
                  </a>
                </article>
              )
            })
          }
        </div>
      )
    }
  </main>
</Layout>

<style is:global>
  .content { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem; }
  .content h1 { margin-bottom: 2rem; }
  .projects-grid { display: grid; gap: 1.25rem; }
  .project-card {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    background: var(--surface);
    transition: background 0.2s;
  }
  .project-card:hover { background: var(--surface-hover); }
  .project-head {
    display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;
  }
  .project-name { font-size: 1.05rem; font-weight: 700; text-transform: capitalize; }
  .live-link {
    font-family: var(--mono); font-size: 0.7rem; color: var(--green);
  }
  .project-desc { color: var(--muted); font-size: 0.88rem; line-height: 1.7; margin-bottom: 0.75rem; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.75rem; }
  .tag {
    font-family: var(--mono); font-size: 0.65rem;
    padding: 0.15rem 0.6rem; border-radius: 3px;
    background: var(--accent-dim); color: var(--accent);
    border: 1px solid var(--accent-border);
  }
  .project-meta {
    display: flex; gap: 1rem; font-family: var(--mono); font-size: 0.65rem;
    color: var(--faint); margin-bottom: 0.75rem;
  }
  .project-link {
    font-family: var(--mono); font-size: 0.72rem; color: var(--accent);
  }
  .project-link:hover { text-decoration: underline; }
  .error-state { text-align: center; padding: 3rem; }
  .error-msg { font-family: var(--mono); color: var(--red); margin-bottom: 1rem; }
  .fallback-link { font-family: var(--mono); color: var(--accent); }
</style>
